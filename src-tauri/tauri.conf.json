{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ONI World Desktop",
  "version": "0.1.0",
  "identifier": "com.wgh.oniworld.desktop",
  "build": {
    "beforeDevCommand": "cd desktop && corepack yarn dev",
    "beforeBuildCommand": "cd desktop && corepack yarn build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../desktop/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ONI World Desktop",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
