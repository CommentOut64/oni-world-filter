{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "oni-world-filter",
    "version":  "0.0.2",
    "identifier":  "com.oni-world-filter",
    "build":  {
                  "beforeDevCommand":  "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/tauri-before-dev.ps1",
                  "beforeBuildCommand":  "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/tauri-before-build.ps1",
                  "devUrl":  "http://127.0.0.1:1420",
                  "frontendDist":  "../desktop/dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "label":  "main",
                                    "title":  "oni-world-filter",
                                    "width":  1280,
                                    "height":  800,
                                    "resizable":  true
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  [
                                   "nsis"
                               ],
                   "resources":  [
                                     "binaries/oni-sidecar.exe",
                                     "binaries/data.zip"
                                 ],
                   "icon":  [
                                "icons/icon.ico"
                            ],
                   "windows":  {
                                   "nsis":  {
                                                "languages":  [
                                                                  "SimpChinese"
                                                              ],
                                                "displayLanguageSelector":  false,
                                                "installMode":  "both",
                                                "installerHooks":  "installer/nsis-hooks.nsh"
                                            }
                               }
               }
}
